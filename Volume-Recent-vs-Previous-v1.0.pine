//@version=6
indicator("Volume Recent vs Previous v1.0", shorttitle="VRVP10", overlay=false)
volCompareN = input.int(30, "Volume Compare N", minval=1)
weakThreshold = input.float(0.80, "Weak Ratio Threshold", minval=0.01, step=0.01)
showRatio = input.bool(true, "Show Volume Ratio")
showWeakMarker = input.bool(true, "Show Weak Marker")
showTable = input.bool(true, "Show Table")
recentVolAvg = ta.sma(volume, volCompareN)
previousVolAvg = ta.sma(volume[volCompareN], volCompareN)
volumeRatio = previousVolAvg != 0.0 and not na(previousVolAvg) ? recentVolAvg / previousVolAvg : na
volumeWeak = not na(volumeRatio) and volumeRatio < weakThreshold
plot(recentVolAvg, "Vol(0~N) / N", color=color.new(color.aqua, 0), linewidth=2)
plot(previousVolAvg, "Vol(N~2N) / N", color=color.new(color.orange, 0), linewidth=2)
plot(showRatio ? volumeRatio : na, "Recent / Previous Vol Ratio", color=color.new(color.purple, 0), linewidth=1, display=display.data_window)
hline(weakThreshold, "Weak Ratio Threshold", color=color.new(color.red, 40), linestyle=hline.style_dashed)
plotshape(showWeakMarker and volumeWeak, title="Recent Volume Weak", style=shape.circle, location=location.top, color=color.new(color.red, 0), size=size.tiny, text="V")
bgcolor(volumeWeak ? color.new(color.red, 90) : na, title="Volume Weak Background")
var table volTable = table.new(position.top_right, 2, 5, border_width=1)
if showTable and barstate.islast
    table.cell(volTable, 0, 0, "Volume Compare", text_color=color.white, bgcolor=volumeWeak ? color.red : color.gray)
    table.cell(volTable, 1, 0, "Value", text_color=color.white, bgcolor=volumeWeak ? color.red : color.gray)
    table.cell(volTable, 0, 1, "N")
    table.cell(volTable, 1, 1, str.tostring(volCompareN))
    table.cell(volTable, 0, 2, "Vol(0~N)/N")
    table.cell(volTable, 1, 2, str.tostring(recentVolAvg, "#.00"))
    table.cell(volTable, 0, 3, "Vol(N~2N)/N")
    table.cell(volTable, 1, 3, str.tostring(previousVolAvg, "#.00"))
    table.cell(volTable, 0, 4, "Ratio")
    table.cell(volTable, 1, 4, na(volumeRatio) ? "n/a" : str.tostring(volumeRatio, "#.00"))
alertcondition(volumeWeak, "Recent Volume Weak", "Recent N-bar average volume is weaker than previous N-bar average volume.")
